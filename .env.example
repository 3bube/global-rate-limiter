# HTTP server
PORT=3000

# Redis (state store for the rate limiter + event stream)
REDIS_URL=redis://redis:6379

# Postgres (analytics / billing log storage)
DATABASE_URL=postgresql://ratelimiter:ratelimiter@postgres:5432/ratelimiter

# Shared secret required (as an x-api-key header) on every /v1 endpoint.
# CHANGE THIS in any real deployment.
API_KEY=dev-api-key

# Circuit breaker tuning
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RESET_TIMEOUT_MS=10000
REDIS_COMMAND_TIMEOUT_MS=75

# Analytics worker
ANALYTICS_BATCH_SIZE=200
ANALYTICS_FLUSH_INTERVAL_MS=1000
# Cap on the usage-events stream (bounded event loss beats unbounded Redis growth)
ANALYTICS_STREAM_MAXLEN=100000
# How long an entry may sit unacked in a dead consumer's pending list before
# another consumer claims it via XAUTOCLAIM
ANALYTICS_CLAIM_MIN_IDLE_MS=60000
# How often the worker sweeps for stale pending entries
ANALYTICS_CLAIM_SWEEP_INTERVAL_MS=30000

# Per-source-IP request budget for the limiter's own API
SELF_IP_LIMIT_PER_MINUTE=600
SELF_RATE_LIMIT_WINDOW_MS=60000
# How many distinct IPs to track before pruning/resetting the in-memory map
SELF_RATE_LIMIT_MAX_TRACKED_IPS=10000
